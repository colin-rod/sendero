# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Site URL (for share functionality)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend Configuration (for email notifications)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
# From address for waitlist confirmation emails (fallback: noreply@senderobiketrails.com)
RESEND_FROM_EMAIL=noreply@senderobiketrails.com

# Google Sheets Integration (for waitlist signups and feedback)
# Deploy an Apps Script web app and paste the URL here
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/your-script-id/exec

# Password Protection (optional - leave blank or set to false to disable)
# Set to 'true' to enable password protection for the entire site
PASSWORD_PROTECTION_ENABLED=false
# The password required to access the site (any password works, server-side only)
SITE_PASSWORD=your-password
# Session encryption secret (minimum 32 characters)
# Generate with: openssl rand -base64 32
SESSION_SECRET=your-32-character-minimum-secret-key

# Linear Feedback Integration
# Configure these in Supabase Dashboard: Project Settings → Edge Functions → Environment Variables
# Get Linear API key from: https://linear.app/settings/api
LINEAR_API_KEY=lin_api_your_key_here
LINEAR_PROJECT_ID=your-linear-project-id
LINEAR_FEEDBACK_TEAM_ID=your-linear-team-id
LINEAR_FEEDBACK_PARENT_ISSUE_ID=your-linear-parent-issue-id

# Linear Label IDs (get from Linear GraphQL API or settings)
# Create 4 labels in your Linear project and obtain their UUIDs
LINEAR_BUG_REPORT_LABEL_ID=label-id-for-bug-reports
LINEAR_FEATURE_REQUEST_LABEL_ID=label-id-for-feature-requests
LINEAR_GENERAL_LABEL_ID=label-id-for-general-feedback
LINEAR_UX_ISSUE_LABEL_ID=label-id-for-ux-issues
